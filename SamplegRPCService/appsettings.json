{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "GrpcHttp2": {
        "Url": "http://*:50051",
        "Protocols": "Http2"
      },
      "GrpcHttp1": {
        "Url": "http://*:50052",
        "Protocols": "Http1"
      }
    },
    "EndpointDefaults": {
      "Protocols": "Http2"

    }
  }
}
