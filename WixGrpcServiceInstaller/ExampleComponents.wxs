<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" 
	 xmlns:utils="http://wixtoolset.org/schemas/v4/wxs/util"
	 xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
	<Fragment>

		<ComponentGroup Id="RuntimeComponentGroup"
						Directory="INSTALLFOLDER">
			<Files Include="publish\runtimes\**"
				   Directory="RUNTIMESFOLDER" />
		</ComponentGroup>


		<ComponentGroup Id="ServiceComponentGroup"
						Directory="INSTALLFOLDER">
			<Files Include="publish\otherfiles\**"/>
			<Component Id="AppSettingsComponent"
					   Guid="{67F1B115-040C-4D76-80F2-D97FFC37FBB9}">
				<File Source="publish\appsettings.json"
					  KeyPath="yes"/>
				<File Source="publish\UpdateConfig.ps1"
					  />
			</Component>
			<Component Id="GrpcServiceInstaller"
					   Guid="{D9A5ACF1-B461-4B1A-A2DC-439F5C9F85D9}">
				<File Source="publish\SamplegRPCService.exe"
					  KeyPath="yes"/>
				<!--<File Source="$(env.ANDROID_HOME)\file.dll"/>-->
				<ServiceInstall Id="ServiceInstaller"
								Type="ownProcess"
								Name="AspnetGRPCService"
								Description="Provides gRPC endpoints for applications"
								DisplayName="gRPC Backend Service"
								Start="auto"
								Account="LocalSystem"
								ErrorControl="normal"/>
				<ServiceControl Id="ServiceController"
								Start="install"
								Stop="both"
								Remove="uninstall"
								Name="AspnetGRPCService"
								Wait="yes"/>
			</Component>
		</ComponentGroup>

	</Fragment>
</Wix>
